{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://w1.local/schemas/w1_match_card_schema.json",
  "title": "W1 Production Lite Match Card with PLAY_GUARD_V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "match",
    "teams",
    "data_sources",
    "markets",
    "squad",
    "lineups",
    "lineup_effect",
    "context",
    "environment_context",
    "odds_movement",
    "market_signal",
    "risk_flags",
    "data_gaps",
    "decision"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "w1_match_card.v1"
    },
    "match": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "match_id",
        "competition",
        "season",
        "round",
        "kickoff_utc",
        "generated_at_utc",
        "venue",
        "referee"
      ],
      "properties": {
        "match_id": {
          "type": "string"
        },
        "competition": {
          "type": "string"
        },
        "season": {
          "type": "integer"
        },
        "round": {
          "type": "string"
        },
        "kickoff_utc": {
          "type": "string",
          "format": "date-time"
        },
        "generated_at_utc": {
          "type": "string",
          "format": "date-time"
        },
        "venue": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "name",
            "city",
            "country",
            "latitude",
            "longitude"
          ],
          "properties": {
            "name": {
              "type": "string"
            },
            "city": {
              "type": "string"
            },
            "country": {
              "type": "string"
            },
            "latitude": {
              "type": [
                "number",
                "null"
              ]
            },
            "longitude": {
              "type": [
                "number",
                "null"
              ]
            }
          }
        },
        "referee": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "name",
            "available"
          ],
          "properties": {
            "name": {
              "type": [
                "string",
                "null"
              ]
            },
            "available": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "teams": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "home",
        "away"
      ],
      "properties": {
        "home": {
          "$ref": "#/$defs/team"
        },
        "away": {
          "$ref": "#/$defs/team"
        }
      }
    },
    "data_sources": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "api_football",
        "open_meteo",
        "fifa_rank",
        "elo",
        "local_snapshots"
      ],
      "properties": {
        "api_football": {
          "$ref": "#/$defs/source_status"
        },
        "open_meteo": {
          "$ref": "#/$defs/source_status"
        },
        "fifa_rank": {
          "$ref": "#/$defs/source_status"
        },
        "elo": {
          "$ref": "#/$defs/source_status"
        },
        "local_snapshots": {
          "$ref": "#/$defs/source_status"
        }
      }
    },
    "markets": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "odds_snapshot_time_utc",
        "first_seen_odds_proxy",
        "odds_1X2",
        "odds_AH",
        "odds_OU"
      ],
      "properties": {
        "odds_snapshot_time_utc": {
          "type": "string",
          "format": "date-time"
        },
        "first_seen_odds_proxy": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "available",
            "captured_at_utc",
            "source",
            "note"
          ],
          "properties": {
            "available": {
              "type": "boolean"
            },
            "captured_at_utc": {
              "type": [
                "string",
                "null"
              ],
              "format": "date-time"
            },
            "source": {
              "type": "string"
            },
            "note": {
              "type": "string"
            }
          }
        },
        "odds_1X2": {
          "$ref": "#/$defs/market"
        },
        "odds_AH": {
          "$ref": "#/$defs/market"
        },
        "odds_OU": {
          "$ref": "#/$defs/market"
        }
      }
    },
    "squad": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "home",
        "away"
      ],
      "properties": {
        "home": {
          "$ref": "#/$defs/squad_status"
        },
        "away": {
          "$ref": "#/$defs/squad_status"
        }
      }
    },
    "lineups": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "confirmed_lineup_available",
        "status",
        "home_starting_xi",
        "away_starting_xi"
      ],
      "properties": {
        "confirmed_lineup_available": {
          "type": "boolean"
        },
        "status": {
          "type": "string",
          "enum": [
            "CONFIRMED",
            "MISSING",
            "PARTIAL"
          ]
        },
        "home_starting_xi": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "away_starting_xi": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "home_substitutes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "away_substitutes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "formation_home": {
          "type": [
            "string",
            "null"
          ]
        },
        "formation_away": {
          "type": [
            "string",
            "null"
          ]
        },
        "home_starting_players": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/lineup_player"
          }
        },
        "away_starting_players": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/lineup_player"
          }
        },
        "home_bench_players": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/lineup_player"
          }
        },
        "away_bench_players": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/lineup_player"
          }
        },
        "lineup_source": {
          "type": "string"
        },
        "lineup_updated_at": {
          "type": "string"
        }
      }
    },
    "lineup_effect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "formation_home",
        "formation_away",
        "formation_changed",
        "home_starter_confidence",
        "away_starter_confidence",
        "key_absences",
        "rotation_flags",
        "attacking_power_effect",
        "defensive_stability_effect",
        "midfield_control_effect",
        "pace_transition_effect",
        "set_piece_effect",
        "pressing_effect",
        "reference_should_recalculate",
        "lineup_summary_cn"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "missing",
            "ready",
            "partial"
          ]
        },
        "formation_home": {
          "type": [
            "string",
            "null"
          ]
        },
        "formation_away": {
          "type": [
            "string",
            "null"
          ]
        },
        "formation_changed": {
          "type": "boolean"
        },
        "home_starter_confidence": {
          "$ref": "#/$defs/lineup_confidence"
        },
        "away_starter_confidence": {
          "$ref": "#/$defs/lineup_confidence"
        },
        "key_absences": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "rotation_flags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "attacking_power_effect": {
          "$ref": "#/$defs/lineup_effect_direction"
        },
        "defensive_stability_effect": {
          "$ref": "#/$defs/lineup_effect_direction"
        },
        "midfield_control_effect": {
          "$ref": "#/$defs/lineup_effect_direction"
        },
        "pace_transition_effect": {
          "$ref": "#/$defs/lineup_effect_direction"
        },
        "set_piece_effect": {
          "$ref": "#/$defs/lineup_effect_direction"
        },
        "pressing_effect": {
          "$ref": "#/$defs/lineup_effect_direction"
        },
        "reference_should_recalculate": {
          "type": "boolean"
        },
        "lineup_summary_cn": {
          "type": "string"
        }
      }
    },
    "context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "standings",
        "recent_form",
        "h2h",
        "injuries",
        "suspensions",
        "weather",
        "travel_distance"
      ],
      "properties": {
        "standings": {
          "$ref": "#/$defs/context_block"
        },
        "recent_form": {
          "$ref": "#/$defs/context_block"
        },
        "h2h": {
          "$ref": "#/$defs/context_block"
        },
        "injuries": {
          "$ref": "#/$defs/context_block"
        },
        "suspensions": {
          "$ref": "#/$defs/context_block"
        },
        "weather": {
          "$ref": "#/$defs/context_block"
        },
        "travel_distance": {
          "$ref": "#/$defs/context_block"
        }
      }
    },
    "environment_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "venue_name",
        "city",
        "country",
        "kickoff_local_time",
        "weather_status",
        "weather_code",
        "temperature_c",
        "humidity_pct",
        "wind_speed_kmh",
        "precipitation_mm",
        "precipitation_probability_pct",
        "weather_snapshot_time",
        "weather_reason_cn",
        "altitude_m",
        "roof_status",
        "environment_risk_level",
        "environment_risk_flags",
        "environment_summary_cn"
      ],
      "properties": {
        "venue_name": {
          "type": "string"
        },
        "city": {
          "type": "string"
        },
        "country": {
          "type": "string"
        },
        "kickoff_local_time": {
          "type": [
            "string",
            "null"
          ]
        },
        "weather_status": {
          "type": "string",
          "enum": [
            "ready",
            "missing",
            "partial",
            "error"
          ]
        },
        "weather_code": {
          "type": [
            "integer",
            "null"
          ]
        },
        "temperature_c": {
          "type": [
            "number",
            "null"
          ]
        },
        "humidity_pct": {
          "type": [
            "number",
            "null"
          ]
        },
        "wind_speed_kmh": {
          "type": [
            "number",
            "null"
          ]
        },
        "precipitation_mm": {
          "type": [
            "number",
            "null"
          ]
        },
        "precipitation_probability_pct": {
          "type": [
            "number",
            "null"
          ]
        },
        "weather_snapshot_time": {
          "type": [
            "string",
            "null"
          ]
        },
        "weather_reason_cn": {
          "type": "string"
        },
        "altitude_m": {
          "type": [
            "number",
            "null"
          ]
        },
        "roof_status": {
          "type": "string",
          "enum": [
            "open",
            "closed",
            "unknown"
          ]
        },
        "environment_risk_level": {
          "type": "string",
          "enum": [
            "LOW",
            "MEDIUM",
            "HIGH"
          ]
        },
        "environment_risk_flags": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "HIGH_TEMP",
              "HIGH_HUMIDITY",
              "HIGH_ALTITUDE",
              "HIGH_WIND",
              "RAIN_RISK",
              "WEATHER_IMPACT_REDUCED",
              "WEATHER_MISSING"
            ]
          }
        },
        "environment_summary_cn": {
          "type": "string"
        }
      }
    },
    "live_refresh": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requested_at",
        "fixture_id",
        "overall_status",
        "modules"
      ],
      "properties": {
        "requested_at": {
          "type": [
            "string",
            "null"
          ]
        },
        "fixture_id": {
          "type": "string"
        },
        "overall_status": {
          "type": "string",
          "enum": [
            "success",
            "partial",
            "failed"
          ]
        },
        "modules": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "odds",
            "lineups",
            "referee",
            "weather",
            "injuries"
          ],
          "properties": {
            "odds": {
              "$ref": "#/$defs/live_refresh_module"
            },
            "lineups": {
              "$ref": "#/$defs/live_refresh_module"
            },
            "referee": {
              "$ref": "#/$defs/live_refresh_module"
            },
            "weather": {
              "$ref": "#/$defs/live_refresh_module"
            },
            "injuries": {
              "$ref": "#/$defs/live_refresh_module"
            }
          }
        }
      }
    },
    "risk_flags": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/flag"
      }
    },
    "data_gaps": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/gap"
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "ledger_required",
        "reasons",
        "play_guard_version",
        "no_betting_commitment"
      ],
      "properties": {
        "label": {
          "type": "string",
          "enum": [
            "W1_PLAY",
            "W1_WATCH",
            "W1_WAIT",
            "W1_PASS"
          ]
        },
        "ledger_required": {
          "type": "boolean"
        },
        "reasons": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "summary",
            "supporting_factors",
            "counter_factors"
          ],
          "properties": {
            "summary": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string"
              }
            },
            "supporting_factors": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "counter_factors": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "no_betting_commitment": {
          "type": "boolean",
          "const": true
        },
        "play_guard_version": {
          "type": "string",
          "enum": [
            "W1_PLAY_GUARD_V1"
          ]
        }
      }
    },
    "odds_movement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "first_seen_at_utc",
        "latest_seen_at_utc",
        "movement_summary",
        "material_change"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "READY",
            "PARTIAL",
            "MISSING"
          ]
        },
        "first_seen_at_utc": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "latest_seen_at_utc": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "movement_summary": {
          "type": "string"
        },
        "material_change": {
          "type": "boolean"
        },
        "odds_1X2_delta": {
          "type": [
            "object",
            "null"
          ]
        },
        "odds_AH_delta": {
          "type": [
            "object",
            "null"
          ]
        },
        "odds_OU_delta": {
          "type": [
            "object",
            "null"
          ]
        }
      }
    },
    "market_signal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "odds_snapshot_age_minutes",
        "odds_1X2_overround",
        "AH_direction_consistent_with_elo",
        "supporting_factors",
        "counter_factors"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "READY",
            "PARTIAL",
            "MISSING"
          ]
        },
        "odds_snapshot_age_minutes": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "odds_1X2_overround": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 1
        },
        "AH_direction_consistent_with_elo": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "supporting_factors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "counter_factors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "$defs": {
    "team": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "team_id",
        "name",
        "fifa_rank",
        "elo_rating"
      ],
      "properties": {
        "team_id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "fifa_rank": {
          "type": [
            "integer",
            "null"
          ]
        },
        "elo_rating": {
          "type": [
            "number",
            "null"
          ]
        }
      }
    },
    "source_status": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "as_of_utc",
        "note"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "OK",
            "PARTIAL",
            "MISSING"
          ]
        },
        "as_of_utc": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "note": {
          "type": "string"
        }
      }
    },
    "market": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "available",
        "bookmakers_count",
        "lines"
      ],
      "properties": {
        "available": {
          "type": "boolean"
        },
        "bookmakers_count": {
          "type": "integer",
          "minimum": 0
        },
        "lines": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      }
    },
    "squad_status": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "available",
        "players_count",
        "source",
        "missing_fields"
      ],
      "properties": {
        "available": {
          "type": "boolean"
        },
        "players_count": {
          "type": "integer",
          "minimum": 0
        },
        "source": {
          "type": "string"
        },
        "missing_fields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "context_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "summary"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "OK",
            "PARTIAL",
            "MISSING"
          ]
        },
        "summary": {
          "type": "string"
        }
      }
    },
    "lineup_confidence": {
      "type": "string",
      "enum": [
        "unknown",
        "low",
        "medium",
        "high"
      ]
    },
    "lineup_effect_direction": {
      "type": "string",
      "enum": [
        "unknown",
        "up",
        "down",
        "stable"
      ]
    },
    "lineup_player": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "number": {
          "type": [
            "integer",
            "null"
          ]
        },
        "position": {
          "type": [
            "string",
            "null"
          ]
        },
        "grid": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "live_refresh_module": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requested",
        "source",
        "status",
        "fetched_at",
        "message_cn"
      ],
      "properties": {
        "requested": {
          "type": "boolean"
        },
        "source": {
          "type": "string",
          "enum": [
            "live_api",
            "cache",
            "fallback",
            "verified_fallback",
            "missing"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "success",
            "empty",
            "error",
            "skipped"
          ]
        },
        "fetched_at": {
          "type": [
            "string",
            "null"
          ]
        },
        "message_cn": {
          "type": "string"
        }
      }
    },
    "flag": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "severity",
        "message"
      ],
      "properties": {
        "code": {
          "type": "string",
          "description": "Risk flag code. REFEREE_UNASSIGNED is required when referee is not assigned."
        },
        "severity": {
          "type": "string",
          "enum": [
            "LOW",
            "MEDIUM",
            "HIGH"
          ]
        },
        "message": {
          "type": "string"
        }
      }
    },
    "gap": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "field",
        "severity",
        "message",
        "blocks_play"
      ],
      "properties": {
        "field": {
          "type": "string"
        },
        "severity": {
          "type": "string",
          "enum": [
            "LOW",
            "MEDIUM",
            "HIGH"
          ]
        },
        "message": {
          "type": "string"
        },
        "blocks_play": {
          "type": "boolean"
        }
      }
    }
  }
}
