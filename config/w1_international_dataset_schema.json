{
  "schema_version": "W1_INTERNATIONAL_DATASET_V1",
  "description": "Unified, leakage-aware schema for the S1B international/national-team backtest seed set. One row per match. Generated by scripts/normalize_w1_international_dataset.py from the seed workbook; raw .xlsx and the generated CSV are gitignored.",
  "pipeline_mode": "1X2_ONLY",
  "w1_full_pipeline_validated": false,
  "row_grain": "one match",
  "field_roles": {
    "prematch_feature": "available before kickoff; may feed a model",
    "label": "derived from the final result; must NEVER feed prediction (leakage guard)",
    "meta": "identifier / provenance / availability flag"
  },
  "fields": {
    "source_sheet": {"type": "string", "role": "meta"},
    "competition": {"type": "string", "role": "meta"},
    "season": {"type": "integer|null", "role": "meta"},
    "match_date": {"type": "date(YYYY-MM-DD)", "role": "prematch_feature", "note": "used for walk-forward split"},
    "phase": {"type": "enum[qualifier,finals]", "role": "prematch_feature"},
    "stage": {"type": "enum[qualifier,group_or_unknown,knockout]", "role": "prematch_feature", "note": "finals knockout inferred from ET/penalties; group vs unknown not separable without round data"},
    "neutral_site": {"type": "bool", "role": "prematch_feature", "note": "finals=true except host nation; qualifiers=false"},
    "is_host_home": {"type": "bool", "role": "prematch_feature"},
    "is_host_away": {"type": "bool", "role": "prematch_feature"},
    "home_name_raw": {"type": "string", "role": "meta"},
    "away_name_raw": {"type": "string", "role": "meta"},
    "home_team_id": {"type": "string", "role": "meta", "note": "canonical id via config/w1_team_aliases.json; never empty (BLOCKER)"},
    "away_team_id": {"type": "string", "role": "meta"},
    "home_goals_90": {"type": "integer|null", "role": "label", "note": "90-minute score for modeling"},
    "away_goals_90": {"type": "integer|null", "role": "label"},
    "finish_type": {"type": "enum[regulation,extra_time,penalties]", "role": "label", "note": "derived from ET/Pens non-null, NOT from Finished"},
    "finished_label_raw": {"type": "string|null", "role": "meta", "note": "raw Finished; unreliable in WorldCup2022"},
    "dirty_finished_label": {"type": "bool", "role": "meta", "note": "true where raw Finished says ET/Penalties but no ET/pen values exist"},
    "home_goals_et": {"type": "number|null", "role": "label"},
    "away_goals_et": {"type": "number|null", "role": "label"},
    "home_penalties": {"type": "number|null", "role": "label", "note": "from HGP"},
    "away_penalties": {"type": "number|null", "role": "label", "note": "from duplicate HGP -> HGP.1"},
    "odds_1x2_home": {"type": "number|null", "role": "prematch_feature"},
    "odds_1x2_draw": {"type": "number|null", "role": "prematch_feature"},
    "odds_1x2_away": {"type": "number|null", "role": "prematch_feature"},
    "odds_1x2_available": {"type": "bool", "role": "meta"},
    "odds_source": {"type": "string", "role": "meta", "note": "avg_consensus or max_or_book"},
    "ou_main_line": {"type": "null", "role": "prematch_feature", "note": "ABSENT in this source"},
    "ou_over_odds": {"type": "null", "role": "prematch_feature"},
    "ou_under_odds": {"type": "null", "role": "prematch_feature"},
    "ou_market_available": {"type": "bool(false)", "role": "meta"},
    "ah_main_line": {"type": "null", "role": "prematch_feature"},
    "ah_market_available": {"type": "bool(false)", "role": "meta"},
    "home_xg": {"type": "number|null", "role": "label", "note": "qualifiers partial (339/889); post-match xG, research-only"},
    "away_xg": {"type": "number|null", "role": "label"},
    "xg_available": {"type": "bool", "role": "meta"},
    "home_shots": {"type": "number|null", "role": "label"},
    "away_shots": {"type": "number|null", "role": "label"},
    "home_sot": {"type": "number|null", "role": "label"},
    "away_sot": {"type": "number|null", "role": "label"},
    "home_corners": {"type": "number|null", "role": "label"},
    "away_corners": {"type": "number|null", "role": "label"},
    "home_fouls": {"type": "number|null", "role": "label"},
    "away_fouls": {"type": "number|null", "role": "label"},
    "stats_available": {"type": "bool", "role": "meta"},
    "pipeline_mode": {"type": "const(1X2_ONLY)", "role": "meta"},
    "w1_full_pipeline_validated": {"type": "const(false)", "role": "meta"},
    "prematch_available": {"type": "bool", "role": "meta"},
    "result_available": {"type": "bool", "role": "meta"}
  },
  "hard_rules": [
    "home_team_id / away_team_id never empty (unmapped name => normalizer aborts; BLOCKER).",
    "modeling uses 90-minute goals; ET/penalties are knockout markers only.",
    "finish_type derived from ET/Pens non-null, not the Finished label.",
    "OU/AH absent => pipeline_mode=1X2_ONLY; never claim full W1 pipeline validated.",
    "label / post-match fields must not feed prediction (leakage guard in w1_backtest_engine.py)."
  ]
}
