{
  "policy_id": "W1_PRODUCTION_LITE_DECISION_POLICY",
  "version": "1.2.0",
  "decision_labels": [
    "W1_PLAY",
    "W1_WATCH",
    "W1_WAIT",
    "W1_PASS"
  ],
  "forbidden_terms": [
    "opening_odds",
    "old official",
    "pending",
    "QQ",
    "命中率"
  ],
  "hard_rules": [
    {
      "id": "confirmed_lineup_required",
      "if": "lineups.confirmed_lineup_available != true",
      "then_label": "W1_WAIT",
      "data_gap_required": true
    },
    {
      "id": "odds_1x2_required",
      "if": "markets.odds_1X2.available != true",
      "then_label": "W1_WAIT",
      "data_gap_required": true
    },
    {
      "id": "odds_ah_required",
      "if": "markets.odds_AH.available != true",
      "then_label": "W1_WAIT",
      "data_gap_required": true
    },
    {
      "id": "odds_ou_required",
      "if": "markets.odds_OU.available != true",
      "then_label": "W1_WAIT",
      "data_gap_required": true
    },
    {
      "id": "squad_required_or_degraded",
      "if": "squad.home.available != true or squad.away.available != true",
      "then_label_one_of": [
        "W1_WAIT",
        "W1_WATCH"
      ],
      "data_gap_required": true
    },
    {
      "id": "partial_suspensions_non_blocking",
      "if": "context.suspensions.status == PARTIAL",
      "then_risk_flag_required": true,
      "blocking": false
    },
    {
      "id": "partial_travel_distance_non_blocking",
      "if": "context.travel_distance.status == PARTIAL",
      "then_risk_flag_required": true,
      "blocking": false
    },
    {
      "id": "play_requires_ledger",
      "if": "decision.label == W1_PLAY",
      "then": "decision.ledger_required == true"
    },
    {
      "id": "play_guard_v1_required_for_play",
      "if": "decision.label == W1_PLAY",
      "then": "all W1_PLAY_GUARD_V1 rules must pass",
      "play_guard_version": "W1_PLAY_GUARD_V1"
    }
  ],
  "label_policy": {
    "W1_PLAY": {
      "ledger_required": true,
      "allowed_when": [
        "confirmed lineup exists",
        "1X2, AH, and OU odds are available",
        "both squads are available",
        "all W1_PLAY_GUARD_V1 quantitative rules pass",
        "ledger_required is true"
      ],
      "play_guard_version": "W1_PLAY_GUARD_V1"
    },
    "W1_WATCH": {
      "ledger_required": false,
      "allowed_when": [
        "non-critical data is partial",
        "squad degradation is explicitly explained",
        "market or context requires observation"
      ]
    },
    "W1_WAIT": {
      "ledger_required": false,
      "allowed_when": [
        "confirmed lineup is missing",
        "required odds market is missing",
        "critical data gap needs refresh"
      ]
    },
    "W1_PASS": {
      "ledger_required": false,
      "allowed_when": [
        "data is sufficient but risk is unacceptable",
        "price or context does not support analysis continuation"
      ]
    }
  },
  "prediction_stage": {
    "version": "W1_EARLY_PREDICTION_MODE_V1",
    "allowed_stages": [
      "EARLY_REFERENCE",
      "PREMATCH_WATCH",
      "FORMAL_DECISION",
      "FINAL_CHECK"
    ],
    "stages": {
      "EARLY_REFERENCE": {
        "time_windows": [
          "T-48h",
          "T-24h"
        ],
        "label_cn": "早盘参考",
        "allowed_outputs": [
          "reference_direction",
          "reference_score",
          "risk_level_cn",
          "current_action_cn",
          "next_update_reason_cn"
        ],
        "ledger_required": false,
        "w1_play_allowed": false,
        "is_final_decision": false,
        "required_disclaimer": "参考比分/参考倾向不是最终结论，不绕过 W1_PLAY_GUARD_V1。"
      },
      "PREMATCH_WATCH": {
        "time_windows": [
          "T-12h",
          "T-6h",
          "T-2h"
        ],
        "label_cn": "赛前观察",
        "allowed_outputs": [
          "reference_direction",
          "reference_score",
          "watch_conclusion",
          "risk_level_cn",
          "current_action_cn",
          "next_update_reason_cn"
        ],
        "ledger_required": false,
        "w1_play_allowed": false,
        "is_final_decision": false,
        "required_disclaimer": "观察结论不是正式 W1_PLAY。"
      },
      "FORMAL_DECISION": {
        "time_windows": [
          "T-1h"
        ],
        "label_cn": "正式判断",
        "allowed_outputs": [
          "final_decision",
          "risk_flags",
          "data_gaps",
          "ledger_required"
        ],
        "requires_confirmed_lineup": true,
        "requires_play_guard": true,
        "w1_play_allowed": true,
        "is_final_decision": true
      },
      "FINAL_CHECK": {
        "time_windows": [
          "T-30m"
        ],
        "label_cn": "最终版",
        "allowed_outputs": [
          "final_check",
          "risk_flags",
          "data_gaps",
          "ledger_required"
        ],
        "requires_confirmed_lineup": true,
        "requires_play_guard": true,
        "w1_play_allowed": true,
        "is_final_decision": true
      }
    },
    "hard_rules": [
      {
        "id": "early_reference_no_ledger_required",
        "if": "prediction_stage == EARLY_REFERENCE",
        "then": "ledger_required == false"
      },
      {
        "id": "early_reference_no_w1_play",
        "if": "prediction_stage == EARLY_REFERENCE",
        "then": "decision.label != W1_PLAY"
      },
      {
        "id": "formal_decision_only_stage_for_w1_play",
        "if": "decision.label == W1_PLAY",
        "then": "prediction_stage in [FORMAL_DECISION, FINAL_CHECK] and W1_PLAY_GUARD_V1 passes"
      },
      {
        "id": "reference_score_non_final",
        "if": "reference_score exists and prediction_stage in [EARLY_REFERENCE, PREMATCH_WATCH]",
        "then": "is_final_decision == false and non_final_disclaimer is present"
      }
    ]
  },
  "play_guard_version": "W1_PLAY_GUARD_V1",
  "play_guard_v1": {
    "description": "W1_PLAY is allowed only when all quantitative guard rules pass. Data completeness alone is not sufficient.",
    "applies_to": "W1_PLAY",
    "all_required": true,
    "rules": [
      {
        "id": "risk_flags_count_max_2",
        "field": "risk_flags.count",
        "operator": "<=",
        "value": 2
      },
      {
        "id": "blocking_data_gaps_zero",
        "field": "blocking_data_gaps",
        "operator": "==",
        "value": 0
      },
      {
        "id": "odds_snapshot_age_under_60m",
        "field": "odds_snapshot_age_minutes",
        "operator": "<",
        "value": 60
      },
      {
        "id": "confirmed_lineup_exists",
        "field": "confirmed_lineup_exists",
        "operator": "==",
        "value": true
      },
      {
        "id": "odds_1X2_overround_under_1_12",
        "field": "odds_1X2_overround",
        "operator": "<",
        "value": 1.12
      },
      {
        "id": "ah_direction_consistent_with_elo",
        "field": "AH_direction_consistent_with_elo",
        "operator": "==",
        "value": true
      },
      {
        "id": "supporting_factors_min_2",
        "field": "supporting_factors.count",
        "operator": ">=",
        "value": 2
      },
      {
        "id": "counter_factors_min_1",
        "field": "counter_factors.count",
        "operator": ">=",
        "value": 1
      },
      {
        "id": "ledger_required_true",
        "field": "ledger_required",
        "operator": "==",
        "value": true
      }
    ]
  }
}
