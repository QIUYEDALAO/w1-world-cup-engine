{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://w1.local/schemas/w1_ledger_schema.json",
  "title": "W1 Production Lite Ledger Entry with PLAY_GUARD_V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "ledger_id",
    "created_at_utc",
    "match_id",
    "decision_label",
    "ledger_required",
    "operator",
    "source_card_sha256",
    "risk_flags",
    "data_gaps",
    "decision_summary",
    "calibration_cycle",
    "override_reason",
    "play_guard_version",
    "prediction_stage",
    "prediction_version",
    "reference_score",
    "final_decision_time",
    "early_prediction_hit",
    "final_prediction_hit",
    "no_betting_commitment"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "w1_ledger.v1"
    },
    "ledger_id": {
      "type": "string"
    },
    "created_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "match_id": {
      "type": "string"
    },
    "decision_label": {
      "type": "string",
      "enum": [
        "W1_PLAY",
        "W1_WATCH",
        "W1_WAIT",
        "W1_PASS"
      ]
    },
    "ledger_required": {
      "type": "boolean"
    },
    "operator": {
      "type": "string"
    },
    "source_card_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "risk_flags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "data_gaps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "decision_summary": {
      "type": "string"
    },
    "manual_override": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "used",
        "reason"
      ],
      "properties": {
        "used": {
          "type": "boolean"
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "no_betting_commitment": {
      "type": "boolean",
      "const": true
    },
    "calibration_cycle": {
      "type": "string",
      "description": "Calibration cycle identifier, for example group_stage_round1_pre_match."
    },
    "override_reason": {
      "type": [
        "string",
        "null"
      ],
      "description": "Required explanation when a manual override is used; null when not used."
    },
    "play_guard_version": {
      "type": "string",
      "enum": [
        "W1_PLAY_GUARD_V1"
      ]
    },
    "prediction_stage": {
      "type": "string",
      "enum": [
        "EARLY_REFERENCE",
        "PREMATCH_WATCH",
        "FORMAL_DECISION",
        "FINAL_CHECK"
      ],
      "description": "Stage at which the ledger entry or review row was produced."
    },
    "prediction_version": {
      "type": "string",
      "const": "W1_EARLY_PREDICTION_MODE_V1"
    },
    "reference_score": {
      "type": [
        "string",
        "null"
      ],
      "description": "Non-final reference score for early/watch stages, null when no reference score was produced."
    },
    "final_decision_time": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time",
      "description": "Timestamp for FORMAL_DECISION or FINAL_CHECK; null for non-final stages."
    },
    "early_prediction_hit": {
      "type": [
        "boolean",
        "null"
      ],
      "description": "Post-match review flag for early reference output; null before review."
    },
    "final_prediction_hit": {
      "type": [
        "boolean",
        "null"
      ],
      "description": "Post-match review flag for formal/final decision output; null before review."
    }
  }
}
