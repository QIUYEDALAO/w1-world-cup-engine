{
  "policy_version": "W1_SCOUT_V1",
  "stage": "W1_SCOUT",
  "purpose": "AI 分析师闭环策略:数据→敢说敢干判断→锁定审计→战绩回灌成长。",

  "boldness": "MEDIUM",
  "boldness_rules": {
    "default_stance": "AGREE",
    "LEAN_DIFFERENT_requires": {"conviction_min": "MEDIUM", "factor_divergence": "present", "min_real_factors": 1},
    "FADE_MARKET_requires": {"conviction_min": "HIGH", "factor_divergence": "clear", "min_real_factors": 2},
    "note_cn": "中间档:默认跟市场;只有真因子(form/xG/伤停/首发)明显背离市场、且 conviction 够高,才偏离或逆。证据不足时禁止逆市场。"
  },

  "conviction_levels": ["LOW", "MEDIUM", "HIGH"],
  "stances": ["AGREE", "LEAN_DIFFERENT", "FADE_MARKET"],

  "call_required_fields": [
    "fixture_id", "call", "market_divergence", "key_factors_cn",
    "conviction", "track_record_context_cn", "honesty_label", "independent_edge"
  ],
  "call_subfields": {
    "call": ["outcome_lean", "scoreline_lean", "confidence"],
    "market_divergence": ["stance", "where_cn", "why_cn"]
  },

  "honesty": {
    "honesty_label_required_substr": "AI 观点",
    "independent_edge_must_be": false,
    "pure_agree_without_why_rejected": true,
    "confidence_must_be_calibrated": true
  },

  "forbidden_terms": ["稳赢", "稳赚", "必中", "必胜", "保证命中", "保证", "资金", "下注", "投注", "梭哈", "盈利承诺", "无风险"],

  "leakage": {
    "bundle_prematch_only": true,
    "forbidden_postmatch_fields": ["actual_score", "fulltime", "result_goals", "home_goals_actual", "away_goals_actual", "post_match", "ft_score"],
    "rule_cn": "scout_bundle 与 call 只用赛前可得;当场赛后统计绝不进入;赛果只在审计阶段对照。"
  },

  "growth": {
    "track_record_path": "state/scout_track_record.json",
    "lessons_path": "state/scout_lessons.md",
    "feed_back_into_call": true,
    "recalibrate_confidence": true,
    "note_cn": "每次开口前先读 track_record + lessons + 校准 → 写进判断依据。成长=经验累积+置信校准,非重训权重。"
  },

  "lock_audit": {
    "lock_path": "state/scout_lock.jsonl",
    "audit_path": "state/scout_audit.jsonl",
    "immutable_lock": true,
    "refuse_hindsight": true,
    "score_vs_market": true,
    "note_cn": "赛前锁定不可变;锁定晚于开赛拒审;赛后既评绝对准度,也评『逆市场时谁对』。"
  },

  "redlines": [
    "允许联网抓取(由你 pipeline 完成);SCOUT 不改 w1_score_engine/DEFAULT_RHO/build λ·矩阵 的市场底座",
    "不造假;赛前判断只用赛前数据;赛后只作审计",
    "不输出投注/资金/命中承诺;每条 call 带 honesty_label + independent_edge=false",
    "不承诺赢市场;敢说敢干=敢表态、敢有据地逆,不等于保证对",
    "输出落 gitignored state/;不碰已跟踪生产文件的底座逻辑"
  ]
}
